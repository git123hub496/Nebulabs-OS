rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEBULABS WEBOS SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a strict User-Ownership model. All personal user data, including
     * profiles, files, and folders, is segregated by the user's unique Firebase Authentication UID.
     * System resources like Applications and Themes are globally readable but strictly immutable 
     * for standard users.
     *
     * DATA STRUCTURE:
     * - /users/{userId}: Primary user profile, keyed by Auth UID.
     * - /users/{userId}/folders/{folderId}: Private virtual folders owned by the specific user.
     * - /users/{userId}/files/{fileId}: Private virtual files owned by the specific user.
     * - /applications/{applicationId}: Global catalog of available WebOS applications.
     * - /themes/{themeId}: Global catalog of available visual themes.
     *
     * KEY SECURITY DECISIONS:
     * - Authorization Independence: Security decisions rely on the {userId} in the path and 
     *   denormalized 'ownerId' or 'id' fields within documents to avoid expensive cross-document lookups.
     * - Self-Creation: Users are permitted to create their own UserProfile document provided the 
     *   document ID matches their authenticated UID.
     * - Structural Segregation: User-specific subcollections ensure that list operations naturally 
     *   filter for only the user's data, providing both performance and security.
     * - Immutable Relationships: Critical relational fields like 'ownerId' are enforced as 
     *   immutable during updates to prevent users from "transferring" ownership or corrupting paths.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document already exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile collection. Users can only access and manage their own profile.
     * @path /users/{userId}
     * @allow (create) if auth.uid is 'abc' and path is /users/abc
     * @deny (create) if auth.uid is 'abc' and path is /users/xyz
     * @principle Ownership and Self-Creation.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for the user's virtual folders.
       * @path /users/{userId}/folders/{folderId}
       * @allow (list) if auth.uid matches the {userId} wildcard.
       * @deny (create) if ownerId in data does not match the {userId} in the path.
       * @principle Subcollection ownership with relational integrity check.
       */
      match /folders/{folderId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.ownerId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.ownerId == resource.data.ownerId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for the user's virtual files.
       * @path /users/{userId}/files/{fileId}
       * @allow (get) if the authenticated user owns the parent path.
       * @deny (update) if the user attempts to change the ownerId field.
       * @principle Subcollection ownership with immutable relational fields.
       */
      match /files/{fileId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.ownerId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.ownerId == resource.data.ownerId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Global applications available in the system.
     * @path /applications/{applicationId}
     * @allow (get, list) for any signed-in user.
     * @deny (create, update, delete) for all users via client SDK.
     * @principle Public read-only system resources.
     */
    match /applications/{applicationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    /**
     * @description Global themes available for customization.
     * @path /themes/{themeId}
     * @allow (get, list) for any signed-in user.
     * @deny (create, update, delete) for all users via client SDK.
     * @principle Public read-only system resources.
     */
    match /themes/{themeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}